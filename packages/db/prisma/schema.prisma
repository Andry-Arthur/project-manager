// MadaProject Database Schema
// AI-Powered Project Management for Malagasy SMBs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION MODELS
// ============================================

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String
  firstName         String
  lastName          String
  phone             String?
  avatar            String?
  role              Role      @default(USER)
  language          Language  @default(FRENCH)
  timezone          String    @default("Indian/Antananarivo")
  isActive          Boolean   @default(true)
  emailVerified     Boolean   @default(false)
  lastLogin         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relationships
  ownedCompanies    Company[] @relation("CompanyOwner")
  companyMemberships CompanyMember[]
  assignedTasks     Task[]    @relation("TaskAssignee")
  createdTasks      Task[]    @relation("TaskCreator")
  notes             Note[]
  notifications     Notification[]
  evaluations       Evaluation[]
  aiInteractions    AIInteraction[]
  settings          UserSettings?

  @@index([email])
  @@index([role])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  USER
  VIEWER
}

enum Language {
  FRENCH
  MALAGASY
  ENGLISH
}

model UserSettings {
  id                String    @id @default(uuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNotifications Boolean   @default(true)
  pushNotifications Boolean   @default(true)
  smsNotifications  Boolean   @default(false)
  voiceAssistant    Boolean   @default(true)
  aiSuggestions     Boolean   @default(true)
  darkMode          Boolean   @default(false)
  ganttView         String    @default("week")
  defaultProjectView String   @default("gantt")
  workingHoursStart String    @default("08:00")
  workingHoursEnd   String    @default("17:00")
  workingDays       String    @default("1,2,3,4,5") // Monday to Friday
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ============================================
// COMPANY & ORGANIZATION MODELS
// ============================================

model Company {
  id                String    @id @default(uuid())
  name              String
  slug              String    @unique
  logo              String?
  industry          String?
  size              CompanySize @default(SMALL)
  address           String?
  city              String?
  region            String?
  country           String    @default("Madagascar")
  phone             String?
  email             String?
  website           String?
  taxId             String?
  currency          String    @default("MGA")
  isActive          Boolean   @default(true)
  subscriptionPlan  String    @default("free")
  subscriptionEnds  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relationships
  owner             User      @relation("CompanyOwner", fields: [ownerId], references: [id])
  ownerId           String
  members           CompanyMember[]
  projects          Project[]
  templates         ProjectTemplate[]
  evaluations       CompanyEvaluation[]

  @@index([slug])
  @@index([ownerId])
}

enum CompanySize {
  MICRO        // 1-9 employees
  SMALL        // 10-49 employees
  MEDIUM       // 50-249 employees
  LARGE        // 250+ employees
}

model CompanyMember {
  id                String    @id @default(uuid())
  companyId         String
  userId            String
  role              MemberRole @default(MEMBER)
  department        String?
  position          String?
  joinDate          DateTime  @default(now())
  isActive          Boolean   @default(true)
  permissions       String?   // JSON string of permissions
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  GUEST
}

// ============================================
// PROJECT MODELS
// ============================================

model Project {
  id                String    @id @default(uuid())
  name              String
  description       String?
  code              String?   // Project code like "PROJ-2024-001"
  companyId         String
  status            ProjectStatus @default(PLANNING)
  priority          Priority  @default(MEDIUM)
  type              ProjectType @default(TRADITIONAL)
  budget            Float?
  currency          String    @default("MGA")
  startDate         DateTime?
  endDate           DateTime?
  actualStartDate   DateTime?
  actualEndDate     DateTime?
  completionPercent Float     @default(0)
  healthScore       Float?    // 0-100 project health
  riskLevel         RiskLevel @default(LOW)
  isTemplate        Boolean   @default(false)
  templateId        String?
  color             String?   // Color for Gantt chart
  icon              String?
  tags              String?   // JSON array of tags
  settings          String?   // JSON project settings
  aiGenerated       Boolean   @default(false)
  aiPrompt          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relationships
  company           Company   @relation(fields: [companyId], references: [id])
  tasks             Task[]
  phases            ProjectPhase[]
  milestones        Milestone[]
  notes             Note[]
  attachments       Attachment[]
  evaluations       Evaluation[]
  timeEntries       TimeEntry[]
  dependencies      TaskDependency[] @relation("ProjectDependencies")
  
  @@index([companyId])
  @@index([status])
  @@index([startDate, endDate])
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum ProjectType {
  TRADITIONAL
  AGILE
  KANBAN
  SCRUM
  WATERFALL
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ProjectPhase {
  id                String    @id @default(uuid())
  projectId         String
  name              String
  description       String?
  order             Int
  color             String?
  startDate         DateTime?
  endDate           DateTime?
  completionPercent Float     @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks             Task[]

  @@index([projectId])
}

model Milestone {
  id                String    @id @default(uuid())
  projectId         String
  name              String
  description       String?
  dueDate           DateTime
  status            MilestoneStatus @default(PENDING)
  completionPercent Float     @default(0)
  color             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([dueDate])
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  MISSED
}

// ============================================
// TASK MODELS
// ============================================

model Task {
  id                String    @id @default(uuid())
  projectId         String
  phaseId           String?
  parentId          String?
  title             String
  description       String?
  status            TaskStatus @default(TODO)
  priority          Priority  @default(MEDIUM)
  type              TaskType  @default(TASK)
  estimateHours     Float?
  actualHours       Float?
  billableHours     Float?
  hourlyRate        Float?
  budget            Float?
  startDate         DateTime?
  endDate           DateTime?
  dueDate           DateTime?
  completedDate     DateTime?
  completionPercent Float     @default(0)
  score             Float?    // Task grading score
  grade             Grade?    // Task grade (A, B, C, D, F)
  gradingCriteria   String?   // JSON grading criteria
  recurrence        String?   // RRULE for recurring tasks
  color             String?
  icon              String?
  tags              String?   // JSON array of tags
  attachments       Int       @default(0)
  comments          Int       @default(0)
  subtasks          Int       @default(0)
  subtasksCompleted Int       @default(0)
  dependencies      String?   // JSON array of dependency task IDs
  predecessors      String?   // JSON array of predecessor task IDs
  order             Int       @default(0)
  isCritical        Boolean   @default(false)
  isMilestone       Boolean   @default(false)
  aiGenerated       Boolean   @default(false)
  aiSuggestions     String?   // JSON AI suggestions
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relationships
  project           Project   @relation(fields: [projectId], references: [id])
  phase             ProjectPhase? @relation(fields: [phaseId], references: [id])
  parent            Task?     @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks          Task[]    @relation("TaskSubtasks")
  assignees         User[]    @relation("TaskAssignee")
  creator           User      @relation("TaskCreator", fields: [creatorId], references: [id])
  creatorId         String
  timeEntries       TimeEntry[]
  comments          TaskComment[]
  attachments       TaskAttachment[]
  grades            TaskGrade[]
  dependencies      TaskDependency[] @relation("TaskDependencies")

  @@index([projectId])
  @@index([status])
  @@index([dueDate])
  @@index([assignees])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  COMPLETED
  CANCELLED
}

enum TaskType {
  TASK
  SUBTASK
  BUG
  FEATURE
  IMPROVEMENT
  MEETING
  REVIEW
  TESTING
}

enum Grade {
  A_PLUS
  A
  A_MINUS
  B_PLUS
  B
  B_MINUS
  C_PLUS
  C
  C_MINUS
  D
  F
}

model TaskComment {
  id                String    @id @default(uuid())
  taskId            String
  userId            String
  content           String
  parentId          String?
  isEdited          Boolean   @default(false)
  mentions          String?   // JSON array of mentioned user IDs
  attachments       String?   // JSON array of attachment URLs
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  task              Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  parent            TaskComment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies           TaskComment[] @relation("CommentReplies")

  @@index([taskId])
  @@index([userId])
}

model TaskAttachment {
  id                String    @id @default(uuid())
  taskId            String
  name              String
  url               String
  type              String    // MIME type
  size              Int
  uploadedBy        String
  createdAt         DateTime  @default(now())

  task              Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskDependency {
  id                String    @id @default(uuid())
  projectId         String
  predecessorTaskId String
  successorTaskId   String
  type              DependencyType @default(FINISH_TO_START)
  lagDays           Int       @default(0)
  isCritical        Boolean   @default(false)
  createdAt         DateTime  @default(now())

  project           Project   @relation(fields: [projectId], references: [id])
  predecessor       Task      @relation("DependencyPredecessor", fields: [predecessorTaskId], references: [id])
  successor         Task      @relation("DependencySuccessor", fields: [successorTaskId], references: [id])

  @@unique([predecessorTaskId, successorTaskId])
  @@index([projectId])
}

enum DependencyType {
  FINISH_TO_START
  START_TO_START
  FINISH_TO_FINISH
  START_TO_FINISH
}

model TaskGrade {
  id                String    @id @default(uuid())
  taskId            String
  userId            String
  criteria          String    // Grading criteria name
  score             Float     // 0-100
  weight            Float     @default(1)
  comment           String?
  gradedAt          DateTime  @default(now())

  task              Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
}

// ============================================
// TIME TRACKING
// ============================================

model TimeEntry {
  id                String    @id @default(uuid())
  taskId            String
  userId            String
  projectId         String
  description       String?
  startTime         DateTime
  endTime           DateTime?
  duration          Int       // Duration in minutes
  billable          Boolean   @default(true)
  hourlyRate        Float?
  amount            Float?
  status            TimeEntryStatus @default(PENDING)
  approvedBy        String?
  approvedAt        DateTime?
  invoiceId         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  task              Task      @relation(fields: [taskId], references: [id])
  user              User      @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
  @@index([projectId])
  @@index([startTime])
}

enum TimeEntryStatus {
  PENDING
  APPROVED
  REJECTED
  INVOICED
}

// ============================================
// NOTES & DOCUMENTATION
// ============================================

model Note {
  id                String    @id @default(uuid())
  projectId         String?
  userId            String
  title             String
  content           String    // Rich text or markdown
  type              NoteType  @default(NOTE)
  isPublic          Boolean   @default(false)
  isPinned          Boolean   @default(false)
  tags              String?   // JSON array of tags
  color             String?
  parentNoteId      String?
  order             Int       @default(0)
  version           Int       @default(1)
  lastEditedBy      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project           Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id])
  versions          NoteVersion[]

  @@index([projectId])
  @@index([userId])
  @@index([type])
}

enum NoteType {
  NOTE
  MEETING
  DOCUMENTATION
  REQUIREMENT
  SPECIFICATION
  REPORT
  TEMPLATE
}

model NoteVersion {
  id                String    @id @default(uuid())
  noteId            String
  content           String
  summary           String?
  version           Int
  changeType        String?   // created, updated, etc.
  changedBy         String?
  createdAt         DateTime  @default(now())

  note              Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
}

// ============================================
// EVALUATIONS & GRADING
// ============================================

model Evaluation {
  id                String    @id @default(uuid())
  projectId         String?
  companyId         String?
  userId            String
  type              EvaluationType
  title             String
  description       String?
  criteria          String    // JSON grading criteria
  scores            String    // JSON scores data
  overallScore      Float     // 0-100
  grade             Grade?
  weight            Float     @default(1)
  status            EvaluationStatus @default(DRAFT)
  isMidProject      Boolean   @default(false)
  isFinal           Boolean   @default(false)
  evaluatorIds      String?   // JSON array of evaluator IDs
  feedback          String?
  recommendations   String?   // JSON recommendations
  nextSteps         String?   // JSON next steps
  dueDate           DateTime?
  completedDate     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project           Project?  @relation(fields: [projectId], references: [id])
  company           Company?  @relation(fields: [companyId], references: [id])
  user              User      @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([companyId])
  @@index([userId])
  @@index([type])
}

enum EvaluationType {
  PROJECT_MASTER
  MID_PROJECT
  FINAL_PROJECT
  TEAM_PERFORMANCE
  INDIVIDUAL_PERFORMANCE
  CLIENT_SATISFACTION
  RISK_ASSESSMENT
  QUALITY_ASSURANCE
}

enum EvaluationStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

model CompanyEvaluation {
  id                String    @id @default(uuid())
  companyId         String
  evaluatorId       String
  criteria          String    // JSON criteria
  scores            String    // JSON scores
  overallScore      Float
  feedback          String?
  recommendations   String?
  createdAt         DateTime  @default(now())

  company           Company   @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

// ============================================
// AI FEATURES
// ============================================

model AIInteraction {
  id                String    @id @default(uuid())
  userId            String
  type              AIInteractionType
  input             String
  output            String?
  context           String?   // JSON context data
  confidence        Float?    // AI confidence score
  metadata          String?   // JSON metadata
  tokensUsed        Int       @default(0)
  cost              Float?
  status            AIStatus  @default(COMPLETED)
  errorMessage      String?
  createdAt         DateTime  @default(now())

  user              User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
}

enum AIInteractionType {
  VOICE_COMMAND
  POINT_CLICK_HELP
  PROJECT_GENERATION
  TASK_SUGGESTION
  SCHEDULE_OPTIMIZATION
  RISK_ANALYSIS
  PERFORMANCE_INSIGHT
  AUTO_FOLLOWUP
  NOTIFICATION_GENERATION
  GRADING_ASSISTANCE
}

enum AIStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id                String    @id @default(uuid())
  userId            String
  type              NotificationType
  title             String
  message           String
  data              String?   // JSON additional data
  isRead            Boolean   @default(false)
  isActioned        Boolean   @default(false)
  actionUrl         String?
  priority          Priority  @default(MEDIUM)
  channel           NotificationChannel
  scheduledAt       DateTime?
  sentAt            DateTime?
  readAt            DateTime?
  actionedAt        DateTime?
  createdAt         DateTime  @default(now())

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([scheduledAt])
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_DUE
  TASK_OVERDUE
  PROJECT_UPDATE
  MENTION
  COMMENT
  EVALUATION_DUE
  MEETING_REMINDER
  AI_SUGGESTION
  SYSTEM_ALERT
  APPROVAL_REQUEST
  TIME_ENTRY_PENDING
}

enum NotificationChannel {
  EMAIL
  PUSH
  SMS
  IN_APP
  VOICE
}

// ============================================
// ATTACHMENTS & FILES
// ============================================

model Attachment {
  id                String    @id @default(uuid())
  projectId         String
  name              String
  originalName      String
  url               String
  type              String    // MIME type
  size              Int
  uploadedBy        String
  description       String?
  tags              String?   // JSON array of tags
  version           Int       @default(1)
  isPublic          Boolean   @default(false)
  downloadCount     Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([uploadedBy])
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id                String    @id @default(uuid())
  userId            String?
  action            String
  entity            String
  entityId          String
  changes           String?   // JSON changes
  ipAddress         String?
  userAgent         String?
  metadata          String?   // JSON metadata
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ============================================
// PROJECT TEMPLATES
// ============================================

model ProjectTemplate {
  id                String    @id @default(uuid())
  companyId         String?
  name              String
  description       String?
  industry          String?
  type              ProjectType @default(TRADITIONAL)
  structure         String    // JSON project structure
  defaultTasks      String?   // JSON default tasks
  defaultPhases     String?   // JSON default phases
  defaultMilestones String?   // JSON default milestones
  gradingCriteria   String?   // JSON grading criteria
  evaluationTemplates String? // JSON evaluation templates
  tags              String?   // JSON array of tags
  isPublic          Boolean   @default(false)
  usageCount        Int       @default(0)
  avgRating         Float?
  createdBy         String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company           Company?  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([industry])
}