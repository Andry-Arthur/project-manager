# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from your Supabase project settings:
# https://app.supabase.com
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_KEY="your-service-role-key"

# PostgreSQL Connection String from Supabase:
# Go to: Project Settings → Database → Connection string → URI
# Use Transaction mode (port 6543) for Prisma
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# JWT SECRET
# ============================================
# Change this in production!
JWT_SECRET="madaproject-super-secret-key-change-in-production"

# ============================================
# OPENAI API KEY (for AI features)
# ============================================
OPENAI_API_KEY=""

# ============================================
# FRONTEND CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# ============================================
# EMAIL CONFIGURATION (for notifications)
# ============================================
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@madaproject.mg"

# ============================================
# SMS CONFIGURATION (for Madagascar SMS)
# ============================================
SMS_API_KEY=""
SMS_API_SECRET=""

# ============================================
# MOBILE MONEY APIs (Madagascar payments)
# ============================================
MVOLA_API_KEY=""
AIRTEL_MONEY_API_KEY=""
ORANGE_MONEY_API_KEY=""

# ============================================
# FILE STORAGE
# ============================================
# Using Supabase Storage for production
# Local uploads for development
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100